# Copy this file to .env (in this same directory) and fill in your values:
#     cp .env.example .env
#
# All pipeline commands are run from this directory (Setup/database).

# --- Supabase (required) -----------------------------------------------------
# From your Supabase project: Connect button, or Settings -> API Keys.
# Use the SECRET / service_role key, never the publishable / anon key.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_...

# --- OpenRouter (required for the RAG report ingest) -------------------------
# From https://openrouter.ai/settings/keys — used to embed the PDF reports.
OPENROUTER_API_KEY=sk-or-v1-...

# --- Kaggle (optional) -------------------------------------------------------
# Only needed if you run the alternative Kaggle RAG ingest (pipelines/ingest.py).
# From kaggle.com -> Settings -> API -> Create New Token.
KAGGLE_USERNAME=
KAGGLE_KEY=
